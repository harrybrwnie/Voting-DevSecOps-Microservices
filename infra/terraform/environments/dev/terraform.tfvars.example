aws_region = "us-east-1"

github_owner = "harrybrwnie"
github_repo  = "Voting-DevSecOps-Microservices"

github_actions_role_name = "github-actions-voting-devsecops-role"

ecr_force_delete = false

vpc_cidr = "10.0.0.0/16"

availability_zones = [
  "us-east-1a",
  "us-east-1b"
]

public_subnet_cidrs = [
  "10.0.1.0/24",
  "10.0.2.0/24"
]

private_subnet_cidrs = [
  "10.0.11.0/24",
  "10.0.12.0/24"
]

enable_nat_gateway = true
single_nat_gateway = false

eks_cluster_name    = "voting-dev-eks"
eks_cluster_version = "1.31"

eks_node_instance_types = [
  "t3.medium"
]

eks_node_min_size     = 1
eks_node_max_size     = 3
eks_node_desired_size = 2